# Files to include in the source distribution (sdist) but not
# necessarily in the built wheel.

include README.md
include LICENSE
include CHANGELOG.md
include ARCHITECTURE.md
include CONTRIBUTING.md
include SECURITY.md
include MANIFEST.in
include pyproject.toml

# Data files the runtime loads at run time.
recursive-include coordpy/_internal/tasks/data *.jsonl

# Trim build/test/dev junk that should never end up in a release.
prune **/__pycache__
prune **/.pytest_cache
prune **/.mypy_cache
prune **/.ruff_cache
prune build
prune dist
prune .git
prune .github
prune docs/archive
recursive-exclude * *.py[cod]
recursive-exclude * *$py.class
recursive-exclude * .DS_Store
global-exclude *.pkl *.pt *.log
